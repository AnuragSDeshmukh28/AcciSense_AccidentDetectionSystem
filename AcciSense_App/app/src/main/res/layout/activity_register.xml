<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Section -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@drawable/btn_gradient"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Join Smart Safety"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_centerInParent="true"/>
        </RelativeLayout>

        <!-- Registration Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="-40dp"
            android:layout_marginBottom="30dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Create Account"
                    android:textColor="@color/primary_navy"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Input Fields with Icons -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <EditText
                        android:id="@+id/regName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Full Name"
                        android:drawableStart="@android:drawable/ic_menu_myplaces"
                        android:drawablePadding="10dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <EditText android:id="@+id/regEmail" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Email Address" android:drawableStart="@android:drawable/ic_dialog_email" android:drawablePadding="10dp"/>
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/passwordLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:helperText="At least 6 chars, start with uppercase, include 1 digit and 1 special char"
                    app:helperTextEnabled="true"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <EditText
                        android:id="@+id/regPass"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:hint="Password"
                        android:drawableStart="@android:drawable/ic_lock_idle_lock"
                        android:drawablePadding="10dp"/>

                </com.google.android.material.textfield.TextInputLayout>
                <!-- Phone Section with OTP Button Inside -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical">

                    <EditText android:id="@+id/regPhone"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Phone (+91...)"
                        android:inputType="phone"/>


                </LinearLayout>

                <EditText
                    android:id="@+id/regOTP"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Verify 6-digit OTP"
                    android:visibility="gone"
                    android:gravity="center"
                    android:letterSpacing="0.2"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/regVehicle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="Vehicle Plate No." />
                <EditText
                    android:id="@+id/regEmergencyName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="Emergency Contact Name" />
                <EditText
                    android:id="@+id/regEmergency"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="Emergency Contact No." />

                <EditText
                    android:id="@+id/regBlood"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="Blood Group" />

                <!-- Final Action Button -->
                <Button
                    android:id="@+id/btnFinalRegister"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="VERIFY &amp; REGISTER"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/btn_gradient"
                    app:backgroundTint="@null" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="already sign up?"
                    android:textColor="@color/primary_navy"
                    android:textStyle="bold"
                    android:id="@+id/logintxt"
                    android:layout_gravity="center"
                    android:gravity="center_horizontal"
                    android:layout_marginTop="15dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>